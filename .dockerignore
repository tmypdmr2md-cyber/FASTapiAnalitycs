# Файлы и каталоги, которые НЕ попадают в build-контекст Docker.
# Чем меньше контекст — тем быстрее сборка и меньше итоговый образ.

# Секреты — никогда не вшивать в образ.
.env
.env.*
!.env.example

# Jupyter-ноутбуки и каталог с ними — не нужны рантайму API.
nbs/
*.ipynb

# Локальные виртуальные окружения и кэши Python — внутри контейнера свой venv.
venv/
.*venv/
__pycache__/
*.py[cod]
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Метаданные репозитория и редакторов — не нужны рантайму.
.git/
.gitignore
.idea/
.vscode/
*.code-workspace
.DS_Store

# Сами Docker-манифесты и доки внутри образа не нужны.
Dockerfile
.dockerignore
README.md
